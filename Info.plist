            <dict><key>default</key><string>CodeWhisper: Explain</string></dict>
            <key>NSMessage</key><string>serviceExplain</string>
            <key>NSSendTypes</key><array><string>public.utf8-plain-text</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key>
            <dict><key>default</key><string>CodeWhisper: Refactor</string></dict>
            <key>NSMessage</key><string>serviceRefactor</string>
            <key>NSSendTypes</key><array><string>public.utf8-plain-text</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key>
            <dict><key>default</key><string>CodeWhisper: Optimize</string></dict>
            <key>NSMessage</key><string>serviceOptimize</string>
            <key>NSSendTypes</key><array><string>public.utf8-plain-text</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key>
            <dict><key>default</key><string>CodeWhisper: Add Comments</string></dict>
            <key>NSMessage</key><string>serviceAddComments</string>

            <key>NSMessage</key><string>serviceWriteTests</string>
            <key>NSSendTypes</key><array><string>public.utf8-plain-text</string></array>
        </dict>
        <dict>
            <key>NSMenuItem</key>
            <dict><key>default</key><string>CodeWhisper: Custom</string></dict>
            <key>NSMessage</key><string>serviceCustom</string>
            <key>NSSendTypes</key><array><string>public.utf8-plain-text</string></array>
        </dict>
    </array>

    <!-- Accessibility usage description for paste-back feature -->
    <key>NSAccessibilityUsageDescription</key>
    <string>CodeWhisper needs Accessibility access to paste AI responses back into your editor.</string>
